{
  "tools": [
    {
      "name": "search_arxiv",
      "description": "Search recent arXiv papers for ML / Robot AI.",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "categories": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "days_back": {
            "type": "integer"
          },
          "max_results": {
            "type": "integer"
          }
        },
        "required": [
          "query",
          "categories"
        ]
      }
    },
    {
      "name": "enrich_metadata",
      "description": "Enrich papers with Semantic Scholar or OpenAlex metadata.",
      "input_schema": {
        "type": "object",
        "properties": {
          "paper_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "providers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "paper_ids",
          "providers"
        ]
      }
    },
    {
      "name": "score_papers",
      "description": "Apply ranking rules and output per-paper scores.",
      "input_schema": {
        "type": "object",
        "properties": {
          "paper_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "profile": {
            "type": "string"
          }
        },
        "required": [
          "paper_ids"
        ]
      }
    },
    {
      "name": "generate_digest",
      "description": "Build daily or weekly digest markdown.",
      "input_schema": {
        "type": "object",
        "properties": {
          "scope": {
            "type": "string",
            "enum": [
              "daily",
              "weekly"
            ]
          },
          "top_k": {
            "type": "integer"
          },
          "tracks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "scope"
        ]
      }
    }
  ]
}